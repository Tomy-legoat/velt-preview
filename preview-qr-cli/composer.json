{
    "name": "velt/preview-qr-cli",
    "description": "CLI preview URL and QR payload generator",
    "autoload": {
        "psr-4": {
            "PreviewQrCli\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../preview-session-store",
            "options": {
                "versions": {
                    "velt/preview-session-store": "1.0.0"
                }
            }
        },
        {
            "type": "path",
            "url": "../preview-contracts",
            "options": {
                "versions": {
                    "velt/preview-contracts": "1.0.0"
                }
            }
        }
    ],
    "require": {
        "velt/preview-session-store": "*",
        "velt/preview-contracts": "*"
    },
    "bin": [
        "bin/velt"
    ]
}
